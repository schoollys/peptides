# ─────────────────────────────────────────────────────────────────────────────
# PeptideTrust — environment template. Copy to .env.local (dev) or set in your
# host's secret store (Vercel/etc) for prod. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data source ──────────────────────────────────────────────────────────────
# "db"  → read from Postgres (DATABASE_URL required)
# unset → in-memory mock (catalog/profile render without a database)
DATA_SOURCE=db

# Managed Postgres connection string. Use TLS (sslmode=require) in prod; never
# point prod at localhost. Example: postgres://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgres://localhost:5432/peptidetrust_dev

# Safety override for demo seeders (db:seed, db:seed:user, db:seed:oracle).
# They refuse to run against a production/remote DB unless this is "1".
# Set ONLY on staging. Never in prod.
ALLOW_DEMO_SEED=

# ── DB connection pool (optional tuning; sane defaults in lib/db.ts) ──────────
# Max pooled connections per instance. Keep low on serverless to avoid storms.
DB_POOL_MAX=5
# Seconds an idle connection is kept before closing.
DB_IDLE_TIMEOUT=20
# Seconds to wait for a new connection before failing.
DB_CONNECT_TIMEOUT=10

# ── Secrets (generate with: openssl rand -base64 32) ─────────────────────────
# HMAC key for signed session cookies. REQUIRED in prod (dev falls back to an
# insecure placeholder).
SESSION_SECRET=
# HMAC key for embeddable badge signatures. Falls back to SESSION_SECRET if unset.
BADGE_SECRET=

# ── Domain vendors (mock until real integrations are wired) ──────────────────
# Switch to real providers before public launch (see docs/go-live-checklist.md §5).
# KYB_PROVIDER:    mock | http   (http → HttpKybProvider, needs KYB_API_*)
# PKI_PROVIDER:    mock | env
#   mock → dev oracle key from .oracle-dev-key.pem (npm run db:seed:oracle).
#   env  → Ed25519 signing key from PKI_PRIVATE_KEY (free, accountless). Key
#          stays out of repo/DB and rotates by swapping the env var. Generate
#          with `npm run pki:keygen`, then publish the matching public key with
#          `npm run pki:sync-oracle`. (A managed cloud KMS can be added later
#          without changing the Ed25519 signature format or verification.)
# ANCHOR_PROVIDER: mock | ots | http
#   ots  → real Bitcoin anchoring via OpenTimestamps (free, no key/account).
#          Hashes are stamped + upgraded out-of-band by the daily anchor cron;
#          set CRON_SECRET so the schedule can run. No ANCHOR_API_* needed.
#   http → HttpAnchorProvider relayer/notary (needs ANCHOR_API_*).
KYB_PROVIDER=mock
PKI_PROVIDER=mock
ANCHOR_PROVIDER=mock

# Ed25519 oracle signing key. Required when PKI_PROVIDER=env. Base64 of the
# PKCS#8 PEM (or the raw PEM). Generate with `npm run pki:keygen`. SECRET.
PKI_PRIVATE_KEY=

# KYB HTTP vendor (Sumsub/Veriff/iDenfy/…). Required when KYB_PROVIDER=http.
KYB_API_URL=
KYB_API_KEY=

# Anchor relayer/notary (L2). Required when ANCHOR_PROVIDER=http. Only the
# opaque hash is ever transmitted (ADR-005), never the payload. Not used by the
# `ots` provider (OpenTimestamps calendars are public and keyless).
ANCHOR_API_URL=
ANCHOR_API_KEY=
ANCHOR_CHAIN=l2

# ── Rate limiting (optional shared store) ────────────────────────────────────
# When both are set, rate limits use Upstash Redis (shared across instances).
# Otherwise the limiter falls back to best-effort in-memory (per-instance).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron (re-anchoring job) ──────────────────────────────────────────────────
# Shared secret guarding GET /api/cron/anchor. On Vercel, set this and the
# platform sends "Authorization: Bearer $CRON_SECRET" to scheduled invocations.
CRON_SECRET=

# ── Email (transactional — password reset, etc.) ─────────────────────────────
# When RESEND_API_KEY is set, mail is delivered via Resend; otherwise the adapter
# falls open (logs the message in dev, warns in prod). See lib/email.ts.
RESEND_API_KEY=
# Verified sender. Falls back to "PeptideTrust <no-reply@peptidetrust.eu>".
EMAIL_FROM=

# ── Observability ────────────────────────────────────────────────────────────
# When set, errors are forwarded to Sentry; otherwise graceful no-op (console).
SENTRY_DSN=
